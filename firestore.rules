rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // REPORTS - 게시글/감상평/기타 신고
    // -------------------------
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow read: if request.auth != null
        && resource.data.reporterUid == request.auth.uid;

      allow update, delete: if false;
    }

    // -------------------------
    // USER REPORTS - 사용자 계정 신고
    // -------------------------
    match /userReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.targetUserId is string
        && request.resource.data.reason is string
        && request.resource.data.status == 'pending';

      allow read, update, delete: if false;
    }

    // -------------------------
    // USERS
    // -------------------------
    match /users/{uid} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && uid == request.auth.uid;

      allow update: if request.auth != null
        && uid == request.auth.uid;

      allow delete: if false;

      match /favoriteCats/{catProfileId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid == uid;
      }

      match /scraps/{scrapId} {
        allow read, write: if request.auth != null
          && uid == request.auth.uid;
      }

      match /blockedUsers/{blockedUid} {
        allow read, create, delete: if request.auth != null
          && request.auth.uid == uid;

        allow update: if false;
      }
    }

    // -------------------------
    // USER IDS
    // -------------------------
    match /userIds/{userId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/userIds/$(userId));

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow update: if false;
    }

    // -------------------------
    // CAT PROFILES
    // -------------------------
    match /catProfiles/{catProfileId} {
      allow read: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          ||
          (
            resource.data.isDeleted != true
            && resource.data.isHidden != true
          )
        );

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if false;
    }

    // -------------------------
    // POSTS
    // -------------------------
    match /posts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'scrapCount',
              'commentCount',
              'unreadReviewCount'
            ])
            && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
          )
        );

      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /reviews/{reviewId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.writerUid == request.auth.uid;

        allow update: if request.auth != null
          && resource.data.writerUid == request.auth.uid;

        allow delete: if request.auth != null
          && resource.data.writerUid == request.auth.uid;
      }
    }

    // -------------------------
    // RAINBOW LETTERS
    // -------------------------
    match /rainbowLetters/{letterId} {
      allow read: if request.auth != null
        && resource.data.isDeleted == false
        && (
          resource.data.isPublic == true
          || resource.data.ownerUid == request.auth.uid
        );

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'todakCount'
            ])
            && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
          )
        );

      allow delete: if false;

      match /todakComments/{commentId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.writerUid == request.auth.uid;

        allow update: if request.auth != null
          && resource.data.writerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'content',
            'isDeleted',
            'updatedAt'
          ])
          && request.resource.data.diff(resource.data).removedKeys().hasOnly([]);

        allow delete: if false;
      }
    }

    // -------------------------
    // NOTICES
    // -------------------------
    match /notices/{noticeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -------------------------
    // UPDATES
    // -------------------------
    match /updates/{updateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -------------------------
    // NOTIFICATIONS
    // -------------------------
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.receiverUid == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid != request.auth.uid
        && request.resource.data.isRead == false;

      allow update: if request.auth != null
        && resource.data.receiverUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    // -------------------------
    // FAVORITE CATS COLLECTION GROUP
    // -------------------------
    match /{path=**}/favoriteCats/{catProfileId} {
      allow read: if request.auth != null;
    }

    // -------------------------
    // DEFAULT DENY
    // -------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}