rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();

      allow create: if isSignedIn();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'processedAt', 'processedBy'])
        && request.resource.data.status in ['pending', 'resolved', 'rejected'];

      allow delete: if false;
    }

   match /userReports/{reportId} {
  allow create: if isSignedIn()
    && request.resource.data.reporterUid == request.auth.uid
    && request.resource.data.targetUid is string
    && request.resource.data.targetUserId is string
    && request.resource.data.reason is string
    && request.resource.data.status == 'pending';

  allow read: if isAdmin()
    || (
      isSignedIn()
      && resource.data.reporterUid == request.auth.uid
    );

  allow update: if isAdmin()
    && request.resource.data.diff(resource.data).affectedKeys()
      .hasOnly(['status', 'processedAt', 'processedBy'])
    && request.resource.data.status in ['pending', 'resolved', 'rejected'];

  allow delete: if false;
}

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && uid == request.auth.uid;

      allow update: if isSignedIn()
        && (
          (
            uid == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'isAdmin',
              'isSuspended'
            ])
          )
          ||
          (
            isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'isSuspended',
              'updatedAt'
            ])
            && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
          )
        );

      allow delete: if false;

      match /favoriteCats/{catProfileId} {
        allow read, create, update, delete: if isSignedIn()
          && request.auth.uid == uid;
      }

      match /scraps/{scrapId} {
        allow read, write: if isSignedIn()
          && uid == request.auth.uid;
      }

      match /blockedUsers/{blockedUid} {
        allow read, create, delete: if isSignedIn()
          && request.auth.uid == uid;

        allow update: if false;
      }
    }

    match /userIds/{userId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/userIds/$(userId));

      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      allow update: if false;
    }

    match /catProfiles/{catProfileId} {
      allow read: if isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          ||
          (
            resource.data.isDeleted != true
            && resource.data.isHidden != true
          )
        );

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          ||
          (
            isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'isHidden',
              'commentCount',
              'updatedAt'
            ])
            && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'scrapCount',
              'commentCount',
              'unreadReviewCount'
            ])
            && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
          )
        );

      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;

      match /reviews/{reviewId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.writerUid == request.auth.uid;

        allow update: if isSignedIn()
          && (
            resource.data.writerUid == request.auth.uid
            ||
            (
              isAdmin()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'isHidden',
                'updatedAt'
              ])
              && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
            )
          );

        allow delete: if isSignedIn()
          && resource.data.writerUid == request.auth.uid;
      }
    }

   match /rainbowLetters/{letterId} {
  allow read: if isSignedIn()
    && (
      isAdmin()
      ||
      (
        resource.data.isDeleted == false
        && (
          resource.data.isPublic == true
          || resource.data.ownerUid == request.auth.uid
        )
      )
    );

  allow create: if isSignedIn()
    && request.resource.data.ownerUid == request.auth.uid;

  allow update: if isSignedIn()
    && (
      resource.data.ownerUid == request.auth.uid
      ||
      (
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isHidden',
          'updatedAt'
        ])
        && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
      )
      ||
      (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'todakCount'
        ])
        && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
      )
    );

  allow delete: if false;

  match /todakComments/{commentId} {
    allow read: if isSignedIn()
      && (
        isAdmin()
        || get(/databases/$(database)/documents/rainbowLetters/$(letterId)).data.isDeleted == false
      );

    allow create: if isSignedIn()
      && request.resource.data.writerUid == request.auth.uid;

    allow update: if isSignedIn()
      && (
        (
          resource.data.writerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'content',
            'isDeleted',
            'updatedAt'
          ])
          && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
        )
        ||
        (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isHidden',
            'updatedAt'
          ])
          && request.resource.data.diff(resource.data).removedKeys().hasOnly([])
        )
      );

    allow delete: if false;
  }
}
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /updates/{updateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.receiverUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid != request.auth.uid
        && request.resource.data.isRead == false;

      allow update: if isSignedIn()
        && resource.data.receiverUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    match /{path=**}/favoriteCats/{catProfileId} {
      allow read: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}